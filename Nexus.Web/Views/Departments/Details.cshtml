@model Department
@{ ViewData["Title"] = "Department Details"; }
<div class="admin-page-title"><h1>@Model.Name</h1><p>@Model.Courses.Count course(s) assigned to this department.</p></div>
<div class="card admin-card"><div class="card-body"><h5>Courses</h5>@if (Model.Courses.Any()) { <ul class="list-group list-group-flush">@foreach (var course in Model.Courses) { <li class="list-group-item">@course.Name <span class="badge bg-light text-dark">@course.Semester</span></li> }</ul> } else { <div class="empty-state">No courses assigned yet.</div> }<div class="mt-3"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a> <a asp-action="Index" class="btn btn-outline-secondary">Back</a></div></div></div>
