@model IEnumerable<Nexus.Data.Models.Enrollment>
@{ ViewData["Title"] = "My Courses"; }
<h1>My Courses</h1><table class="table"><thead><tr><th>Course</th><th>Semester</th><th>Teacher</th><th></th></tr></thead><tbody>
@foreach (var e in Model) { <tr><td>@e.Course?.Name</td><td>@e.Course?.Semester</td><td>@(e.Course?.Teacher?.DisplayName ?? e.Course?.Teacher?.Email)</td><td><a asp-action="Materials" asp-route-courseId="@e.CourseId">Download Course Material</a></td></tr> }
</tbody></table>
