@model IEnumerable<Nexus.Web.ViewModels.Student.StudentAssignmentViewModel>
@{ ViewData["Title"] = "Assignments"; }
<h1>Assignments</h1><table class="table"><thead><tr><th>Course</th><th>Title</th><th>Deadline</th><th>Status</th><th></th></tr></thead><tbody>
@foreach (var a in Model) { <tr><td>@a.CourseName</td><td>@a.Title</td><td>@a.Deadline</td><td>@a.Status</td><td><a asp-action="SubmitAssignment" asp-route-id="@a.Id">Submit</a> | <a asp-action="AssignmentHistory" asp-route-assignmentId="@a.Id">History</a></td></tr> }
</tbody></table>
