@model Nexus.Web.ViewModels.Student.StudentDashboardViewModel
@{ ViewData["Title"] = "Student Dashboard"; }
<h1>Student Dashboard</h1><p><a class="btn btn-outline-primary" asp-action="Courses">Courses</a> <a class="btn btn-outline-primary" asp-action="Assignments">Assignments</a> <a class="btn btn-outline-primary" asp-action="Grades">Grades</a> <a class="btn btn-outline-primary" asp-controller="Quizzes" asp-action="Available">Quizzes</a></p>
<h2>Courses</h2><ul>@foreach (var c in Model.Courses) { <li>@c.Name (@c.Semester) - @c.TeacherName</li> }</ul>
<h2>Assignments</h2><table class="table"><thead><tr><th>Course</th><th>Assignment</th><th>Deadline</th><th>Status</th><th></th></tr></thead><tbody>@foreach (var a in Model.Assignments) { <tr><td>@a.CourseName</td><td>@a.Title</td><td>@a.Deadline</td><td>@a.Status</td><td><a asp-action="SubmitAssignment" asp-route-id="@a.Id">Submit</a></td></tr> }</tbody></table>
