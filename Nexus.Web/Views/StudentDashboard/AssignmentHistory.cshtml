@model IEnumerable<Nexus.Data.Models.Submission>
@{ ViewData["Title"] = "Submission History"; }
<h1>Submission History - @ViewBag.AssignmentTitle</h1><table class="table"><thead><tr><th>Submitted</th><th>Status</th><th>File</th><th>Feedback</th></tr></thead><tbody>@foreach (var s in Model) { <tr><td>@s.SubmittedAt</td><td>@s.Status</td><td><a href="@s.FilePath" download>Download</a></td><td>@s.Feedback</td></tr> }</tbody></table>
