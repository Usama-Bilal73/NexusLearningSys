@{
    ViewData["Title"] = "Password reset requested";
}

<div class="alert alert-info">
    If the email is registered, a password reset link has been created.
</div>
@if (TempData["PasswordResetLink"] is string resetLink)
{
    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h5">Development reset link</h2>
            <p class="text-muted">Configure an email sender before production. Use this link to complete the reset flow now:</p>
            <a href="@resetLink" class="btn btn-outline-primary">Reset password</a>
        </div>
    </div>
}
