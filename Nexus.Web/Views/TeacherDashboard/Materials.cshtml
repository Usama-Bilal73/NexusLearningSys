@model IEnumerable<Nexus.Data.Models.CourseMaterial>
@{ ViewData["Title"] = "Course Materials"; }

<section class="page-hero mb-4">
    <div>
        <span class="eyebrow">Teaching library</span>
        <h1>Course Materials</h1>
        <p>Organize every handout, lecture note, syllabus, and lab guide in a clean library your students can trust.</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-primary" asp-action="UploadMaterial">Upload Material</a>
        <a class="btn btn-outline-primary" asp-controller="DocumentRepository" asp-action="Index">Open Repository</a>
    </div>
</section>

<section class="insight-card">
    <div class="table-responsive">
        <table class="table admin-table align-middle mb-0">
            <thead><tr><th>Material</th><th>Course</th><th>Category</th><th>Type</th><th>Uploaded</th><th></th></tr></thead>
            <tbody>
            @foreach (var m in Model)
            {
                <tr>
                    <td><strong>@m.Title</strong><br /><small class="text-muted">@m.OriginalFileName</small></td>
                    <td>@m.Course?.Name</td>
                    <td><span class="badge bg-primary-subtle text-primary">@m.Category</span></td>
                    <td>@m.MaterialType</td>
                    <td>@m.UploadedAtUtc.ToLocalTime().ToString("g")</td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="@m.FilePath" download>Download</a></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state mt-3">No materials uploaded yet. Start by adding a polished resource for your students.</div>
    }
</section>
