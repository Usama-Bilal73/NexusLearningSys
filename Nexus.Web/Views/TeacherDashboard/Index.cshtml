@model Nexus.Web.ViewModels.Teacher.TeacherDashboardViewModel
@{ ViewData["Title"] = "Teacher Dashboard"; }
<h1>Teacher Dashboard</h1>
<p>
    <a class="btn btn-primary" asp-action="CreateAssignment">Create Assignment</a>
    <a class="btn btn-secondary" asp-action="UploadMaterial">Upload Course Material</a>
    <a class="btn btn-outline-primary" asp-controller="DocumentRepository" asp-action="Upload">Upload Repository Document</a>
    <a class="btn btn-outline-primary" asp-controller="Gradebook" asp-action="Index">Gradebook</a>
    <a class="btn btn-outline-primary" asp-controller="Quizzes" asp-action="Index">Quizzes</a>
</p>
@if (Model.AtRiskAlerts.Any())
{
    <div class="alert alert-warning">
        <h2 class="h5">At-Risk Student Alerts</h2>
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead><tr><th>Student</th><th>Course</th><th>Status</th><th>Reason</th><th>Assignments</th><th>Quiz Avg</th><th>Submissions</th></tr></thead>
                <tbody>
                @foreach (var alert in Model.AtRiskAlerts)
                {
                    <tr>
                        <td>@alert.StudentName</td>
                        <td>@alert.CourseName</td>
                        <td><span class="badge bg-danger">@alert.Status</span></td>
                        <td>@alert.Reason</td>
                        <td>@alert.AssignmentAverage.ToString("0.##")%</td>
                        <td>@alert.QuizAverage.ToString("0.##")</td>
                        <td>@alert.SubmissionCount / @alert.AssignmentCount</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
<table class="table"><thead><tr><th>Course</th><th>Semester</th><th>Students</th><th>Assignments</th><th>Materials</th></tr></thead><tbody>
@foreach (var c in Model.Courses) { <tr><td>@c.Name</td><td>@c.Semester</td><td>@c.StudentCount</td><td>@c.AssignmentCount</td><td>@c.MaterialCount</td></tr> }
</tbody></table>
