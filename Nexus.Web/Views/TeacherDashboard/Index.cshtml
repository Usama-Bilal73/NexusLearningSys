@model Nexus.Web.ViewModels.Teacher.TeacherDashboardViewModel
@{ ViewData["Title"] = "Teacher Dashboard"; }

<section class="dashboard-hero teacher-hero mb-4">
    <div>
        <span class="eyebrow">Teacher workspace</span>
        <h1>Welcome back to your command center</h1>
        <p>Track courses, publish assignments, manage learning materials, and spot students who need support from one polished dashboard.</p>
    </div>
    <div class="hero-actions">
        <a class="btn btn-light" asp-action="CreateAssignment">Create Assignment</a>
        <a class="btn btn-outline-light" asp-action="UploadMaterial">Upload Material</a>
    </div>
</section>

<div class="quick-actions mb-4">
    <a class="quick-action" asp-controller="DocumentRepository" asp-action="Upload"><span>📄</span><strong>Repository Upload</strong><small>PDF, DOCX, PPTX</small></a>
    <a class="quick-action" asp-controller="Gradebook" asp-action="Index"><span>📊</span><strong>Gradebook</strong><small>Review performance</small></a>
    <a class="quick-action" asp-controller="Quizzes" asp-action="Index"><span>✅</span><strong>Quizzes</strong><small>Manage assessments</small></a>
    <a class="quick-action" asp-controller="CourseAssistant" asp-action="Index"><span>✨</span><strong>AI Assistant</strong><small>Course support</small></a>
</div>

@if (Model.AtRiskAlerts.Any())
{
    <section class="insight-card warning-card mb-4">
        <div class="section-heading">
            <div>
                <span class="eyebrow text-warning">Attention needed</span>
                <h2>At-risk student alerts</h2>
            </div>
            <span class="badge rounded-pill bg-warning text-dark">@Model.AtRiskAlerts.Count alerts</span>
        </div>
        <div class="table-responsive">
            <table class="table admin-table align-middle mb-0">
                <thead><tr><th>Student</th><th>Course</th><th>Status</th><th>Reason</th><th>Assignments</th><th>Quiz Avg</th><th>Submissions</th></tr></thead>
                <tbody>
                @foreach (var alert in Model.AtRiskAlerts)
                {
                    <tr>
                        <td><strong>@alert.StudentName</strong></td>
                        <td>@alert.CourseName</td>
                        <td><span class="badge bg-danger-subtle text-danger">@alert.Status</span></td>
                        <td>@alert.Reason</td>
                        <td>@alert.AssignmentAverage.ToString("0.##")%</td>
                        <td>@alert.QuizAverage.ToString("0.##")</td>
                        <td>@alert.SubmissionCount / @alert.AssignmentCount</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}

<section class="insight-card">
    <div class="section-heading">
        <div>
            <span class="eyebrow">Assigned courses</span>
            <h2>Your courses at a glance</h2>
        </div>
    </div>
    @if (Model.Courses.Any())
    {
        <div class="course-grid">
        @foreach (var c in Model.Courses)
        {
            <article class="course-card">
                <div class="course-icon">@c.Name.FirstOrDefault()</div>
                <div>
                    <h3>@c.Name</h3>
                    <p>@c.Semester</p>
                </div>
                <dl>
                    <div><dt>Students</dt><dd>@c.StudentCount</dd></div>
                    <div><dt>Assignments</dt><dd>@c.AssignmentCount</dd></div>
                    <div><dt>Materials</dt><dd>@c.MaterialCount</dd></div>
                </dl>
            </article>
        }
        </div>
    }
    else
    {
        <div class="empty-state">No courses are assigned to your profile yet.</div>
    }
</section>
