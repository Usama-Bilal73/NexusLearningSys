@model IEnumerable<Nexus.Data.Models.Semester>
@{
    ViewData["Title"] = "Semester Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">🗓️ Semester Management</h1>
        <p class="text-muted small mb-0">Manage academic sessions and activate semesters</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> New Semester
    </a>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Semester Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@s.Name</div>
                                @if (!string.IsNullOrEmpty(s.Description))
                                {
                                    <small class="text-muted">@s.Description</small>
                                }
                            </td>
                            <td>@s.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@s.EndDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @{
                                    var days = (s.EndDate - s.StartDate).Days;
                                    var weeks = days / 7;
                                }
                                <span class="text-muted">@weeks weeks</span>
                            </td>
                            <td>
                                @if (s.IsActive)
                                {
                                    <span class="badge bg-success fs-6 px-3 py-2"><i class="bi bi-check-circle me-1"></i>Active</span>
                                }
                                else if (s.EndDate < DateTime.Today)
                                {
                                    <span class="badge bg-secondary px-3 py-2">Completed</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark px-3 py-2">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm">
                                    @if (!s.IsActive)
                                    {
                                        <form asp-action="SetActive" asp-route-id="@s.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-success" title="Set as Active">
                                                <i class="bi bi-lightning-fill me-1"></i>Activate
                                            </button>
                                        </form>
                                    }
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-outline-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@s.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Delete semester @s.Name?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x display-4 d-block mb-2"></i>
                                No semesters yet. <a asp-action="Create">Create the first one</a>.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
