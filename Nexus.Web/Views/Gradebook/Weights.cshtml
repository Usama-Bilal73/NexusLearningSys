@model Nexus.Data.Models.GradeWeight
@{
    ViewData["Title"] = "Configure Course Weights";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0 text-center">Configure Course Grading Weights</h4>
                </div>
                <div class="card-body p-4">
                    <h5 class="card-title text-secondary mb-4 text-center">Course: @ViewBag.CourseName</h5>
                    
                    <form asp-action="Weights" method="post">
                        <input type="hidden" asp-for="CourseId" />
                        
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="AssignmentWeight" class="form-label font-weight-bold">Assignment Weight (%)</label>
                            <div class="input-group">
                                <input asp-for="AssignmentWeight" class="form-control" type="number" step="0.01" min="0" max="100" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="AssignmentWeight" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MidtermWeight" class="form-label font-weight-bold">Midterm Weight (%)</label>
                            <div class="input-group">
                                <input asp-for="MidtermWeight" class="form-control" type="number" step="0.01" min="0" max="100" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="MidtermWeight" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FinalWeight" class="form-label font-weight-bold">Final Exam Weight (%)</label>
                            <div class="input-group">
                                <input asp-for="FinalWeight" class="form-control" type="number" step="0.01" min="0" max="100" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="FinalWeight" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="QuizWeight" class="form-label font-weight-bold">Quizzes Weight (%)</label>
                            <div class="input-group">
                                <input asp-for="QuizWeight" class="form-control" type="number" step="0.01" min="0" max="100" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="QuizWeight" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info py-2" role="alert">
                            <small><i class="fas fa-info-circle me-1"></i> The sum of all weights must equal exactly <strong>100%</strong>.</small>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg">Save Weights & Recalculate Grades</button>
                            <a asp-action="Index" asp-route-courseId="@Model.CourseId" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
