@model IEnumerable<Nexus.Web.ViewModels.Gradebook.GradeEntryViewModel>
@{ ViewData["Title"] = "Gradebook"; }
<h1>Gradebook</h1><table class="table"><thead><tr><th>Course</th><th>Student</th><th>Assignment</th><th>Midterm</th><th>Final</th><th>Total</th><th></th></tr></thead><tbody>@foreach (var g in Model) { <tr><td>@g.CourseName</td><td>@g.StudentName</td><td>@g.AssignmentMarks</td><td>@g.MidtermMarks</td><td>@g.FinalMarks</td><td>@g.TotalMarks</td><td><a asp-action="Edit" asp-route-studentId="@g.StudentId" asp-route-courseId="@g.CourseId">Enter Marks</a></td></tr> }</tbody></table>
