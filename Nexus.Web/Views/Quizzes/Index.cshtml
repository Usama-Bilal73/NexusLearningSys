@model IEnumerable<Nexus.Data.Models.Quiz>
@{ ViewData["Title"] = "Quizzes"; }
<h1>Quizzes</h1><p><a class="btn btn-primary" asp-action="Create">Create Quiz</a> <a class="btn btn-outline-secondary" asp-action="QuestionBank">Question Bank</a></p><table class="table"><thead><tr><th>Course</th><th>Title</th><th>Questions</th><th>Timer</th><th>Published</th><th></th></tr></thead><tbody>@foreach (var q in Model) { <tr><td>@q.Course?.Name</td><td>@q.Title</td><td>@q.Questions.Count</td><td>@q.DurationMinutes min</td><td>@q.IsPublished</td><td><a asp-action="Details" asp-route-id="@q.Id">Manage</a><form asp-action="Delete" asp-route-id="@q.Id" method="post" class="d-inline"><button class="btn btn-link text-danger">Delete</button></form></td></tr> }</tbody></table>
