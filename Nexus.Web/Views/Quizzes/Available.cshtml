@model IEnumerable<Nexus.Data.Models.Quiz>
@{ ViewData["Title"] = "Available Quizzes"; }
<h1>Available Quizzes</h1><table class="table"><thead><tr><th>Course</th><th>Quiz</th><th>Timer</th><th></th></tr></thead><tbody>@foreach (var q in Model) { <tr><td>@q.Course?.Name</td><td>@q.Title</td><td>@q.DurationMinutes min</td><td><a class="btn btn-primary btn-sm" asp-action="Take" asp-route-id="@q.Id">Take Quiz</a></td></tr> }</tbody></table>
