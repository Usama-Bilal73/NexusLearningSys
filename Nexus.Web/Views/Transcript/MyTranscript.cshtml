@model TranscriptViewModel
@{
    ViewData["Title"] = "Academic Transcript";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">🎓 Academic Transcript</h1>
        <p class="text-muted mb-0">@Model.StudentName — @Model.Email</p>
    </div>
    <a asp-controller="Reports" asp-action="DownloadTranscript" class="btn btn-danger">
        <i class="bi bi-file-earmark-pdf me-1"></i>Download PDF
    </a>
</div>

<!-- CGPA Banner -->
<div class="card border-0 mb-4 shadow-sm" style="background: linear-gradient(135deg, #1a1a2e, #16213e);">
    <div class="card-body text-white d-flex align-items-center gap-4 p-4">
        <div class="text-center">
            <div class="display-4 fw-bold text-warning">@Model.Cgpa.ToString("0.00")</div>
            <div class="small text-white-50">Cumulative GPA</div>
        </div>
        <div class="vr bg-white opacity-25 mx-2" style="height:60px;"></div>
        <div>
            <div class="fw-semibold fs-5">@Model.StudentName</div>
            <div class="text-white-50">@Model.Email</div>
            <div class="text-white-50 small mt-1">@Model.Rows.Count course(s) on record</div>
        </div>
    </div>
</div>

@if (Model.Rows.Any())
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Course</th>
                            <th>Semester</th>
                            <th class="text-center">Assign.</th>
                            <th class="text-center">Midterm</th>
                            <th class="text-center">Final</th>
                            <th class="text-center">Quiz</th>
                            <th class="text-center">Total</th>
                            <th class="text-center">Grade</th>
                            <th class="text-center">GPA</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            var gradeColor = row.LetterGrade.StartsWith("A") ? "success" :
                                             row.LetterGrade.StartsWith("B") ? "primary" :
                                             row.LetterGrade.StartsWith("C") ? "warning" :
                                             row.LetterGrade == "D"          ? "secondary" : "danger";
                            <tr>
                                <td class="fw-semibold">@row.CourseName</td>
                                <td class="text-muted">@row.Semester</td>
                                <td class="text-center">@row.AssignmentMarks.ToString("0.##")</td>
                                <td class="text-center">@row.MidtermMarks.ToString("0.##")</td>
                                <td class="text-center">@row.FinalMarks.ToString("0.##")</td>
                                <td class="text-center">@row.QuizMarks.ToString("0.##")</td>
                                <td class="text-center fw-bold">@row.TotalMarks.ToString("0.##")</td>
                                <td class="text-center">
                                    <span class="badge bg-@gradeColor fs-6 px-2">@row.LetterGrade</span>
                                </td>
                                <td class="text-center fw-semibold">@row.GpaPoints.ToString("0.0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="8" class="text-end fw-bold">Cumulative GPA (CGPA):</td>
                            <td class="text-center fw-bold text-warning fs-5">@Model.Cgpa.ToString("0.00")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-mortarboard display-3 d-block mb-3"></i>
        <h5>No grade records yet</h5>
        <p>Your transcript will appear here once your teacher enters your grades.</p>
    </div>
}
