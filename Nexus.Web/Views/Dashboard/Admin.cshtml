@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="admin-hero mb-4">
    <div>
        <span class="eyebrow">Nexus control center</span>
        <h1>Admin Dashboard</h1>
        <p>Manage people, departments, and courses with fast search, polished workflows, and clean governance.</p>
    </div>
    <div>
        <a class="btn btn-light btn-lg me-2" asp-controller="RoleManagement" asp-action="Index">Role Management</a>
        <a class="btn btn-primary btn-lg" asp-controller="Analytics" asp-action="Index">Analytics</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6 col-xl-3">
        <a class="admin-tile" asp-controller="Teachers" asp-action="Index">
            <span class="tile-icon">👩‍🏫</span>
            <strong>Manage Teachers</strong>
            <small>Faculty profiles, credentials, and access.</small>
        </a>
    </div>
    <div class="col-md-6 col-xl-3">
        <a class="admin-tile" asp-controller="Students" asp-action="Index">
            <span class="tile-icon">🎓</span>
            <strong>Manage Students</strong>
            <small>Learner accounts and onboarding.</small>
        </a>
    </div>
    <div class="col-md-6 col-xl-3">
        <a class="admin-tile" asp-controller="Departments" asp-action="Index">
            <span class="tile-icon">🏛️</span>
            <strong>Manage Departments</strong>
            <small>Academic units and course grouping.</small>
        </a>
    </div>
    <div class="col-md-6 col-xl-3">
        <a class="admin-tile" asp-controller="Courses" asp-action="Index">
            <span class="tile-icon">📚</span>
            <strong>Manage Courses</strong>
            <small>Semesters, instructors, and curriculum.</small>
        </a>
    </div>
</div>
