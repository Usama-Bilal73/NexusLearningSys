@model AdminUserFormViewModel
@{ ViewData["Title"] = "Delete Student"; }
<div class="admin-page-title"><h1>Delete Student</h1><p>This permanently removes @Model.FirstName @Model.LastName.</p></div>
<div class="card border-danger admin-card"><div class="card-body"><h4>@Model.FirstName @Model.LastName</h4><p class="text-muted">@Model.Email</p><form asp-action="Delete" method="post"><input type="hidden" asp-for="Id" /><button class="btn btn-danger">Delete</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a></form></div></div>
