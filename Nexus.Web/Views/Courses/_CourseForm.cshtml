@model CourseFormViewModel
<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
<div class="row g-3">
    <div class="col-md-6"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control form-control-lg" placeholder="e.g. Advanced Databases" /><span asp-validation-for="Name" class="text-danger"></span></div>
    <div class="col-md-6"><label asp-for="Semester" class="form-label"></label><input asp-for="Semester" class="form-control form-control-lg" placeholder="e.g. Fall 2026" /><span asp-validation-for="Semester" class="text-danger"></span></div>
    <div class="col-md-6"><label asp-for="TeacherId" class="form-label"></label><select asp-for="TeacherId" asp-items="Model.Teachers" class="form-select form-select-lg"><option value="">Select teacher</option></select><span asp-validation-for="TeacherId" class="text-danger"></span></div>
    <div class="col-md-6"><label asp-for="DepartmentId" class="form-label"></label><select asp-for="DepartmentId" asp-items="Model.Departments" class="form-select form-select-lg"><option value="">Unassigned</option></select><span asp-validation-for="DepartmentId" class="text-danger"></span></div>
</div>
