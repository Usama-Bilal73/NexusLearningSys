@model IEnumerable<Nexus.Data.Identity.ApplicationUser>
@{
    ViewData["Title"] = "Mark Attendance";
    var courseId  = (int)ViewBag.CourseId;
    var markDate  = (DateTime)ViewBag.Date;
    var existing  = (Dictionary<string, string>)ViewBag.Existing;
    var statuses  = (string[])ViewBag.Statuses;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 fw-bold">✅ Mark Attendance</h1>
        <p class="text-muted small mb-0">@ViewBag.CourseName</p>
    </div>
    <a asp-action="Report" asp-route-courseId="@courseId" class="btn btn-outline-secondary">
        <i class="bi bi-bar-chart me-1"></i> View Report
    </a>
</div>

<div class="card shadow-sm border-0 mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <input type="hidden" name="courseId" value="@courseId" />
            <div class="col-auto">
                <label class="form-label fw-semibold">Date</label>
                <input type="date" name="date" class="form-control" value="@markDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary">Load</button>
            </div>
        </form>
    </div>
</div>

<form asp-action="MarkSave" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="courseId" value="@courseId" />
    <input type="hidden" name="date" value="@markDate.ToString("yyyy-MM-dd")" />

    <div class="card shadow-sm border-0">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-semibold">📅 @markDate.ToString("dddd, dd MMMM yyyy")</span>
            <div class="btn-group btn-group-sm">
                <button type="button" class="btn btn-outline-success" onclick="markAll('Present')">All Present</button>
                <button type="button" class="btn btn-outline-danger" onclick="markAll('Absent')">All Absent</button>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Student</th>
                        @foreach (var s in statuses)
                        {
                            <th class="text-center">@s</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{ int i = 1; }
                    @foreach (var student in Model)
                    {
                        var currentStatus = existing.TryGetValue(student.Id, out var st) ? st : "Present";
                        <tr>
                            <td class="text-muted">@i</td>
                            <td>
                                <div class="fw-semibold">@(student.DisplayName ?? student.Email)</div>
                                <small class="text-muted">@student.Email</small>
                            </td>
                            @foreach (var status in statuses)
                            {
                                <td class="text-center">
                                    <div class="form-check d-inline-block">
                                        <input class="form-check-input status-radio" type="radio"
                                               name="statuses[@student.Id]"
                                               value="@status"
                                               id="s_@(student.Id)_@status"
                                               @(currentStatus == status ? "checked" : "") />
                                    </div>
                                </td>
                            }
                        </tr>
                        i++;
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary px-5">
                <i class="bi bi-save me-1"></i>Save Attendance
            </button>
        </div>
    </div>
</form>

@section Scripts {
<script>
    function markAll(status) {
        document.querySelectorAll('.status-radio[value="' + status + '"]').forEach(r => r.checked = true);
    }
</script>
}
