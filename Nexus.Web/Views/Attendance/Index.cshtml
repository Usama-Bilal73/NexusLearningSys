@model IEnumerable<Nexus.Data.Models.Course>
@{
    ViewData["Title"] = "Attendance Management";
}

<section class="page-hero mb-4">
    <div>
        <span class="eyebrow">Mark or view records</span>
        <h1>Attendance Management</h1>
        <p>Select one of your assigned courses below to mark student attendance or view attendance reports.</p>
    </div>
</section>

<div class="insight-card">
    <div class="section-heading mb-4">
        <div>
            <h2>Your Assigned Courses</h2>
        </div>
    </div>
    @if (!Model.Any())
    {
        <div class="empty-state">No courses are assigned to your profile yet.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var course in Model)
            {
                <div class="list-group-item d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div>
                        <h4 class="mb-1 text-white">@course.Name</h4>
                        <small class="text-muted">Semester: @course.Semester</small>
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-primary btn-sm" asp-action="Mark" asp-route-courseId="@course.Id">
                            <i class="fa fa-calendar-plus me-1"></i>Mark Attendance
                        </a>
                        <a class="btn btn-outline-primary btn-sm" asp-action="Report" asp-route-courseId="@course.Id">
                            <i class="fa fa-chart-line me-1"></i>Attendance Report
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
