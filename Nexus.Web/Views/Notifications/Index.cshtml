@model IReadOnlyList<Nexus.Data.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Notifications</h1>
    <form method="post" asp-action="MarkAllAsRead">
        @Html.AntiForgeryToken()
        <button class="btn btn-outline-primary">Mark all as read</button>
    </form>
</div>

<div class="list-group">
@foreach(var n in Model)
{
    <a asp-action="Details" asp-route-id="@n.Id" class="list-group-item list-group-item-action @(n.IsRead ? "" : "fw-bold")">
        <div class="d-flex w-100 justify-content-between">
            <h5 class="mb-1">@n.Title</h5>
            <small class="text-muted">@n.CreatedAtUtc.ToString("g")</small>
        </div>
        <p class="mb-1">@n.Message</p>
        <small class="text-muted">Type: @n.NotificationType</small>
    </a>
}
</div>
