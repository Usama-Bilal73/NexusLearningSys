@using Nexus.Data.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav account-nav ms-lg-3 align-items-lg-center">
@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = currentUser?.DisplayName ?? User.Identity?.Name ?? "User";
    var initial = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName[..1].ToUpperInvariant();
    <li class="nav-item">
        <a class="nav-link user-pill" asp-controller="Dashboard" asp-action="Index">
            <span class="user-avatar">@initial</span>
            <span class="user-label">@displayName</span>
        </a>
    </li>
    <li class="nav-item">
        <form class="d-inline" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-outline-primary btn-sm rounded-pill px-3">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="btn btn-primary btn-sm rounded-pill px-3" asp-controller="Account" asp-action="Login">Login</a>
    </li>
}
</ul>
