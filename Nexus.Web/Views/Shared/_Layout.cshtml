<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexus Learning System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Nexus.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Nexus Learning System</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            @if (User.IsInRole(ApplicationRoles.Teacher))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Teacher</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="TeacherDashboard" asp-action="Index">Assigned Courses</a></li>
                                        <li><a class="dropdown-item" asp-controller="TeacherDashboard" asp-action="Assignments">Assignments</a></li>
                                        <li><a class="dropdown-item" asp-controller="TeacherDashboard" asp-action="Materials">Course Materials</a></li>
                                        <li><a class="dropdown-item" asp-controller="Gradebook" asp-action="Index">Gradebook</a></li>
                                        <li><a class="dropdown-item" asp-controller="Quizzes" asp-action="Index">Quizzes</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole(ApplicationRoles.Student))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Student</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="StudentDashboard" asp-action="Courses">Courses</a></li>
                                        <li><a class="dropdown-item" asp-controller="StudentDashboard" asp-action="Assignments">Assignments</a></li>
                                        <li><a class="dropdown-item" asp-controller="StudentDashboard" asp-action="Grades">Grades</a></li>
                                        <li><a class="dropdown-item" asp-controller="Quizzes" asp-action="Available">Quizzes</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole(ApplicationRoles.Admin))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Admin</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Teachers" asp-action="Index">Teachers</a></li>
                                        <li><a class="dropdown-item" asp-controller="Students" asp-action="Index">Students</a></li>
                                        <li><a class="dropdown-item" asp-controller="Departments" asp-action="Index">Departments</a></li>
                                        <li><a class="dropdown-item" asp-controller="Courses" asp-action="Index">Courses</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-controller="RoleManagement" asp-action="Index">Role Management</a></li>
                                    </ul>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Nexus Learning System - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
