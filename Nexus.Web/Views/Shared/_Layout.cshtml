<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexus Learning System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Nexus.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="app-header">
        <nav class="navbar navbar-expand-lg navbar-light app-navbar">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand brand-mark" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Nexus Learning System home">
                    <span class="brand-icon">N</span>
                    <span>
                        <span class="brand-title">Nexus</span>
                        <span class="brand-subtitle">Learning System</span>
                    </span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#primaryNavigation" aria-controls="primaryNavigation"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div id="primaryNavigation" class="navbar-collapse collapse">
                    <ul class="navbar-nav main-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                            </li>
                            @if (User.IsInRole(ApplicationRoles.Teacher))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Teacher</a>
                                    <ul class="dropdown-menu app-dropdown">
                                        <li><a class="dropdown-item" asp-controller="TeacherDashboard" asp-action="Index">Assigned Courses</a></li>
                                        <li><a class="dropdown-item" asp-controller="TeacherDashboard" asp-action="Assignments">Assignments</a></li>
                                        <li><a class="dropdown-item" asp-controller="TeacherDashboard" asp-action="Materials">Course Materials</a></li>
                                        <li><a class="dropdown-item" asp-controller="DocumentRepository" asp-action="Index">Document Repository</a></li>
                                        <li><a class="dropdown-item" asp-controller="CourseAssistant" asp-action="Index">AI Course Assistant</a></li>
                                        <li><a class="dropdown-item" asp-controller="Gradebook" asp-action="Index">Gradebook</a></li>
                                        <li><a class="dropdown-item" asp-controller="Quizzes" asp-action="Index">Quizzes</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole(ApplicationRoles.Student))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Student</a>
                                    <ul class="dropdown-menu app-dropdown">
                                        <li><a class="dropdown-item" asp-controller="StudentDashboard" asp-action="Courses">Courses</a></li>
                                        <li><a class="dropdown-item" asp-controller="StudentDashboard" asp-action="Assignments">Assignments</a></li>
                                        <li><a class="dropdown-item" asp-controller="StudentDashboard" asp-action="Grades">Grades</a></li>
                                        <li><a class="dropdown-item" asp-controller="DocumentRepository" asp-action="Index">Documents</a></li>
                                        <li><a class="dropdown-item" asp-controller="CourseAssistant" asp-action="Index">AI Course Assistant</a></li>
                                        <li><a class="dropdown-item" asp-controller="Quizzes" asp-action="Available">Quizzes</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole(ApplicationRoles.Admin))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">Admin</a>
                                    <ul class="dropdown-menu app-dropdown">
                                        <li><a class="dropdown-item" asp-controller="Teachers" asp-action="Index">Teachers</a></li>
                                        <li><a class="dropdown-item" asp-controller="Students" asp-action="Index">Students</a></li>
                                        <li><a class="dropdown-item" asp-controller="Departments" asp-action="Index">Departments</a></li>
                                        <li><a class="dropdown-item" asp-controller="Courses" asp-action="Index">Courses</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item" asp-controller="RoleManagement" asp-action="Index">Role Management</a></li>
                                    </ul>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                            </li>
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell container-fluid px-3 px-lg-4">
        <main role="main" class="app-content">
            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div class="container-fluid px-3 px-lg-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2">
            <span>&copy; 2026 Nexus Learning System</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy &amp; data protection</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
